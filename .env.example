# 钉钉机器人 Webhook 地址（必填）
# 获取方式：钉钉群 → 群设置 → 智能群助手 → 添加机器人 → 自定义 → 复制 Webhook 地址
# 示例：https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxxxxxx
DINGTALK_WEBHOOK=

# 钉钉机器人加签密钥（可选，但强烈建议启用）
# 创建机器人时选择"加签"安全设置，复制以 SEC 开头的密钥
# 示例：SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DINGTALK_SECRET=

# 状态文件路径（可选，默认 data/last_state.json）
STATE_FILE=data/last_state.json
